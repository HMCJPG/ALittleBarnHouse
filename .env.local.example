# Copy to .env.local and fill in once you've created a KV / Upstash
# database via Vercel's marketplace. Locally, the app falls back to an
# in-memory store if these are absent — fine for poking at the UI, but
# notes won't sync between you and won't survive a restart.
#
# Easiest way to get these: after wiring the database in the Vercel
# dashboard, run `vercel env pull .env.local` from this project's root
# (with the Vercel CLI installed).

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash marketplace integrations sometimes use these names instead —
# the app accepts either pair.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Spotify Web Playback SDK / Web API credentials. Both required for the
# record player to actually play music. Get from
# https://developer.spotify.com/dashboard after registering an app.
# Make sure your app's redirect URIs include:
#   https://<your-domain>/api/spotify/callback
#   http://localhost:3000/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
